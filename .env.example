# Server Environment
# Options: development, staging, production
ENV=development

# Logging Level
# Options: debug, info, warn, error
LOG_LEVEL=info

# API Keys
POLYMARKET_API_KEY=your_polymarket_key_here
ODDS_API_KEY=your_odds_api_key_here

# Database
# Format: postgres://user:password@host:port/database?sslmode=disable
POSTGRES_URL=postgres://polyuser:polypassword@localhost:5432/polydata?sslmode=disable

# Docker Compose Postgres (override defaults if needed)
POSTGRES_USER=polyuser
POSTGRES_PASSWORD=polypassword
POSTGRES_DB=polydata
TIMESCALEDB_TELEMETRY_DISABLED=off