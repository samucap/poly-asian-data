{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://poly-asian.local/schemas/edge_board_v2.json",
  "title": "edge_board_v2",
  "type": "object",
  "required": [
    "schema_version",
    "pipeline_version",
    "run_id",
    "generated_at",
    "input_hash",
    "code_commit",
    "status",
    "errors",
    "strategy",
    "board_stats",
    "board",
    "dropped_summary"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2.0" },
    "strategy": { "type": "string" },
    "board_stats": {
      "type": "object",
      "properties": {
        "n_candidates": { "type": "integer" },
        "n_stage1": { "type": "integer" },
        "n_board": { "type": "integer" },
        "median_edge_bps": { "type": "number" },
        "enrich_coverage": { "type": "number" },
        "cycle_ms": { "type": "integer" },
        "enrich_ms": { "type": "integer" }
      }
    },
    "board": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rank", "condition_id", "token_ids", "score", "edge_bps"],
        "properties": {
          "rank": { "type": "integer" },
          "condition_id": { "type": "string" },
          "edge_bps": { "type": ["number", "null"] },
          "cost_bps": { "type": ["number", "null"] },
          "capacity_usd": { "type": ["number", "null"] },
          "key_features": { "type": "object" },
          "risk_flags": { "type": "array", "items": { "type": "string" } },
          "fair_value": { "type": ["number", "null"] },
          "model_edge_bps": { "type": ["number", "null"] }
        }
      }
    },
    "dropped_summary": { "type": "object" }
  },
  "additionalProperties": true
}
